$TTL 60
@ IN SOA ns1.dosarena.local. admin.dosarena.local. (
    2024010101 3600 900 604800 60 )

; NS records
@ IN NS  ns1.dosarena.local.
@ IN NS  ns2.dosarena.local.

; A records
ns1      IN A 10.0.2.30
ns2      IN A 10.0.2.30
@        IN A 10.0.2.30
www      IN A 10.0.2.30
mail     IN A 10.0.2.30
ftp      IN A 10.0.2.30
vpn      IN A 10.0.2.30
dev      IN A 10.0.2.30
api      IN A 10.0.2.30
lab      IN A 10.0.2.30

; MX records
@ IN MX 10 mail.dosarena.local.
@ IN MX 20 mail2.dosarena.local.
@ IN MX 30 mail3.dosarena.local.
mail2    IN A 10.0.2.30
mail3    IN A 10.0.2.30

; TXT records — bulk up response for amplification (~60x factor)
@ IN TXT "v=spf1 ip4:10.0.2.0/24 ip4:10.0.3.0/24 ip4:192.168.0.0/16 include:dosarena.local ~all"
@ IN TXT "dosarena-verification=aabbccddeeff00112233445566778899aabbccddeeff001122334455"
@ IN TXT "description=DOSArena intentionally vulnerable DNS open resolver for amplification training"
@ IN TXT "contact=lab@dosarena.local location=DOSArena-Docker-Lab version=1.0 purpose=training"
@ IN TXT "k=rsa; p=MIGfMA0GCSqGSIb3DQEBAQUAA4GNADCBiQKBgQC7s9wuQUH7BZaabbccddeeff00112233445566778899"
_dmarc   IN TXT "v=DMARC1; p=none; rua=mailto:dmarc@dosarena.local; fo=1"
_domainkey IN TXT "t=y; o=~;"
